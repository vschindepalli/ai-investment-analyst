# Copy to .env and fill in. The app runs without these (uses mock data +
# hash-based embeddings + template explainer), but you'll want them for real
# behavior.

# --- Embeddings ---
# Provider: "ollama" (default, local), "openai", or "hash" (offline).
EMBEDDING_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=embeddinggemma

# --- LLM (OpenAI) — explanation layer only ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Only used when EMBEDDING_PROVIDER=openai.
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Supabase ---
SUPABASE_URL=
SUPABASE_KEY=

# --- App ---
ALLOWED_ORIGINS=http://localhost:3000
