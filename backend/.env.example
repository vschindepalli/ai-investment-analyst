# Copy to .env and fill in. The app still runs without this, but these values
# enable real providers instead of mock fallbacks.

# --- Embeddings ---
# Provider: "ollama" (default, local), "openai", or "hash" (offline).
EMBEDDING_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=embeddinggemma

# --- LLM (local Ollama chat) ---
OLLAMA_CHAT_MODEL=gemini-3-flash-preview:latest
# faster alternative if responses are slow: qwen2.5:3b
OLLAMA_CHAT_TIMEOUT=45
OLLAMA_CHAT_NUM_PREDICT=256
OLLAMA_CHAT_ENABLED=true
OPENAI_API_KEY=

# Only used when EMBEDDING_PROVIDER=openai.
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Supabase ---
SUPABASE_URL=
SUPABASE_KEY=

# --- App ---
ALLOWED_ORIGINS=http://localhost:3000
